}

local function getSpectateHumanoid(player)
    local char = player.Character or player.CharacterAdded:Wait()
    return char:WaitForChild("Humanoid", 5)
end

local function setMenuVisibility(visible)
    pcall(function()
        local rest = LocalPlayer.PlayerGui.ClientGui.Mainframe.Rest
        for _, name in ipairs({ "BackDrop", "MainMenuFrame" }) do
            local child = rest:FindFirstChild(name)
