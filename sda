--           FRUIT ESP SYSTEM
-- ══════════════════════════════════════

local FruitESPSettings = {
    Enabled      = false,
    FruitTree    = false,
    Selected     = {},
    TextSize     = 16,
    TextDistance = 1000,
}

local FRUIT_NAMES = {
    "Chakra Fruit", "Life Up Fruit", "Fruit Of Forgetfulness",
    "Apple", "Alluring Apple", "Banana", "Mango", "Pear", "Orange",
}

local FRUIT_COLORS = {
    ["Life Up Fruit"]          = Color3.fromRGB(0,   255, 0),
    ["Chakra Fruit"]           = Color3.fromRGB(255, 100, 255),
    ["Fruit Of Forgetfulness"] = Color3.fromRGB(255, 90,  90),
}

local fruitESPObjects     = {}  -- [obj] = { label, name }
local fruitTreeESPObjects = {}  -- [model] = label
local fruitRenderConn     = nil
local fruitDescConn       = nil

local function isFruitSelected(fruitName)
    local sel = FruitESPSettings.Selected
    if sel[fruitName] ~= nil then return sel[fruitName] end
    for _, v in ipairs(sel) do if v == fruitName then return true end end
    return false
end

local function createFruitESP(obj, displayName)
    if fruitESPObjects[obj] then return end
    local color = FRUIT_COLORS[displayName] or Color3.fromRGB(255, 200, 80)
    local lbl = newESPText(color)
    fruitESPObjects[obj] = { label = lbl, name = displayName }
end

local function destroyFruitESP(obj)
    local d = fruitESPObjects[obj]
    if not d then return end
    d.label:Remove(); fruitESPObjects[obj] = nil
end

local function destroyAllFruitESP()
    for o in pairs(fruitESPObjects) do destroyFruitESP(o) end
end

local function createFruitTreeESP(model)
    if fruitTreeESPObjects[model] then return end
    fruitTreeESPObjects[model] = newESPText(Color3.fromRGB(100, 220, 80))
end

local function destroyFruitTreeESP(model)
    local t = fruitTreeESPObjects[model]
    if not t then return end
    t:Remove(); fruitTreeESPObjects[model] = nil
end

local function destroyAllFruitTreeESP()
    for m in pairs(fruitTreeESPObjects) do destroyFruitTreeESP(m) end
end

local function isFruitTree(obj)
    return obj:IsA("Model") and obj.Name:find("Tree") ~= nil
        and obj:FindFirstChild("FruitType") ~= nil
end

local function scanForFruit(fruitName)
    local v1 = fruitName
    local v2 = fruitName:gsub(" ", "_")
    for _, child in ipairs(workspace:GetChildren()) do
        if child:IsA("BasePart") and (child.Name == v1 or child.Name == v2) then
            createFruitESP(child, fruitName)
        end
    end
    for _, child in ipairs(ReplicatedStorage:GetChildren()) do
        if child:IsA("BasePart") and (child.Name == v1 or child.Name == v2) then
            createFruitESP(child, fruitName)
        end
    end
end

local function scanAllSelectedFruits()
    for _, fruitName in ipairs(FRUIT_NAMES) do
        if isFruitSelected(fruitName) then
            scanForFruit(fruitName)
        end
    end
end

local function startFruitLoop()
    if fruitRenderConn then return end
    fruitRenderConn = RunService.RenderStepped:Connect(function()
        local camera   = workspace.CurrentCamera
        local camPos   = camera.CFrame.Position
        local textSize = FruitESPSettings.TextSize
        local textFont = ESPSettings.TextFont
        local maxDist  = FruitESPSettings.TextDistance

        -- Fruit objects
        local toCleanFruits = {}
        for obj, data in pairs(fruitESPObjects) do
            if not obj.Parent then
                data.label.Visible = false
                table.insert(toCleanFruits, obj)
                continue
            end
            if not FruitESPSettings.Enabled then data.label.Visible = false; continue end
            local pos = getObjPos(obj)
            if not pos then data.label.Visible = false; continue end
            local dist = (pos - camPos).Magnitude
            local sp, onScreen = camera:WorldToViewportPoint(pos + Vector3.new(0, 2, 0))
            if not onScreen or dist > maxDist then data.label.Visible = false; continue end
            data.label.Size     = textSize
            data.label.Font     = textFont
            data.label.Text     = string.format("%s\n%.0fm", data.name, dist)
            data.label.Position = Vector2.new(sp.X, sp.Y)
            data.label.Visible  = true
        end
        for _, o in ipairs(toCleanFruits) do destroyFruitESP(o) end

        -- Fruit trees
        local toCleanTrees = {}
        for model, label in pairs(fruitTreeESPObjects) do
            if not model.Parent then
                label.Visible = false
                table.insert(toCleanTrees, model)
                continue
            end
            if not FruitESPSettings.FruitTree then label.Visible = false; continue end
            local ftVal = model:FindFirstChild("FruitType")
            local pos   = getObjPos(model)
            if not pos then label.Visible = false; continue end
            local dist = (pos - camPos).Magnitude
            local sp, onScreen = camera:WorldToViewportPoint(pos + Vector3.new(0, 4, 0))
            if not onScreen or dist > maxDist then label.Visible = false; continue end
            label.Size     = textSize
            label.Font     = textFont
            label.Text     = string.format("%s Tree%.0fm", ftVal and ftVal.Value or model.Name, dist)
            label.Position = Vector2.new(sp.X, sp.Y)
            label.Visible  = true
        end
        for _, m in ipairs(toCleanTrees) do destroyFruitTreeESP(m) end
    end)
end

local function stopFruitLoop()
    if fruitRenderConn then fruitRenderConn:Disconnect(); fruitRenderConn = nil end
end

local function isAnyFruitEnabled()
    if FruitESPSettings.FruitTree then return true end
    if not FruitESPSettings.Enabled then return false end
    for _, fruitName in ipairs(FRUIT_NAMES) do
        if isFruitSelected(fruitName) then return true end
    end
    return false
end

local function hookFruitDescendants()
    if fruitDescConn then fruitDescConn:Disconnect() end
    fruitDescConn = workspace.ChildAdded:Connect(function(obj)
        task.wait()
        if not obj or not obj.Parent then return end
        if FruitESPSettings.Enabled and obj:IsA("BasePart") then
            local objName = obj.Name
            for _, fruitName in ipairs(FRUIT_NAMES) do
                if isFruitSelected(fruitName) then
                    if objName == fruitName or objName == fruitName:gsub(" ", "_") then
                        createFruitESP(obj, fruitName)
                        break
                    end
                end
            end
        end
        if FruitESPSettings.FruitTree and isFruitTree(obj) then
            createFruitTreeESP(obj)
        end
    end)
end

local function updateFruitHooks()
    if isAnyFruitEnabled() then
        hookFruitDescendants()
        startFruitLoop()
    else
        if fruitDescConn then fruitDescConn:Disconnect(); fruitDescConn = nil end
        stopFruitLoop()
    end
end

local function setFruitESP(enabled)
    FruitESPSettings.Enabled = enabled
    if enabled then
        scanAllSelectedFruits()
    else
        destroyAllFruitESP()
    end
    updateFruitHooks()
end

local function setFruitTreeESP(enabled)
    FruitESPSettings.FruitTree = enabled
    if enabled then
        for _, obj in ipairs(workspace:GetChildren()) do
            if isFruitTree(obj) then createFruitTreeESP(obj) end
        end
    else
        destroyAllFruitTreeESP()
    end
    updateFruitHooks()
end

