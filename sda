-- Auto Pickup --
local autoPickupConnection = nil

local function autoPickup(state)
    if not state then
        if autoPickupConnection then
            autoPickupConnection:Disconnect()
            autoPickupConnection = nil
        end
        return
    end

    local params = OverlapParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = { LocalPlayer.Character }

    local lastPickupTime = 0
    autoPickupConnection = RunService.Heartbeat:Connect(function()
        local now = tick()
        if now - lastPickupTime < 0.5 then return end
        lastPickupTime = now

        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        params.FilterDescendantsInstances = { char }

        local ok, parts = pcall(workspace.GetPartBoundsInBox, workspace, hrp.CFrame, Vector3.new(50, 50, 50), params)
        if not ok then return end

        for _, v in ipairs(parts) do
            local distance = (v.Position - hrp.Position).Magnitude
            if distance > 25 then continue end

            if v:FindFirstChild("SpawnTime") and v:FindFirstChild("ItemDetector") then
                pcall(fireclickdetector, v.ItemDetector)
            elseif v:FindFirstChild("Pickupable") then
                if not v:FindFirstChild("ItemDetector") and distance > 15 then continue end
                local idValue = v:FindFirstChild("ID", true)
                if idValue then
                    pcall(function()
                        ReplicatedStorage.Events.DataEvent:FireServer("PickUp", idValue.Value)
                    end)
                end
            end
        end
    end)
end

-- Anti Void --
local antiVoidDisabled = {}
local antiVoidConn     = nil

local function disableVoidPart(part)
    if not part or not part:IsA("BasePart") then return end
    if antiVoidDisabled[part] then return end
    antiVoidDisabled[part] = true
    pcall(function() part.CanTouch = false end)
end

local function antiVoid(state)
    if antiVoidConn then
        antiVoidConn:Disconnect()
        antiVoidConn = nil
    end

    if not state then
        for part in pairs(antiVoidDisabled) do
            pcall(function() part.CanTouch = true end)
        end
        antiVoidDisabled = {}
        return
    end

    -- Initial scan: Script named "Void" → disable CanTouch on its parent part
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.ClassName == "Script" and obj.Name == "Void" then
            disableVoidPart(obj.Parent)
        end
    end

    -- Watch for new Void scripts added at runtime
    antiVoidConn = workspace.DescendantAdded:Connect(function(obj)
        if obj.ClassName == "Script" and obj.Name == "Void" then
            task.defer(function() disableVoidPart(obj.Parent) end)
        end
    end)
end

