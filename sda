local function setBlurEnabled(enabled)
    pcall(function()
        for _, v in ipairs(Lighting:GetChildren()) do
            if v:IsA("BlurEffect") or v:IsA("DepthOfFieldEffect") then
                v.Enabled = enabled
            end
        end
        -- also handle older PointBlur instance name --
        local pb = Lighting:FindFirstChild("PointBlur")
        if pb then pb.Enabled = enabled end
    end)
end

local function spectatePlayer(name)
    local target = Players:FindFirstChild(name)
    if not target then
        Notifier.new({ Title = "Spectate", Content = "Player not found: " .. name, Duration = 3 })
        return
    end

    local humanoid = getSpectateHumanoid(target)
    if not humanoid then
        Notifier.new({ Title = "Spectate", Content = "Could not find humanoid for: " .. name, Duration = 3 })
        return
    end

    workspace.CurrentCamera.CameraSubject = humanoid
    Spectate.currentTarget = name
    setMenuVisibility(false)
    setBlurEnabled(false)

    Notifier.new({ Title = "Spectate", Content = "Spectating: " .. name, Duration = 3 })
end

local function stopSpectating()
    local char     = LocalPlayer.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        workspace.CurrentCamera.CameraSubject = humanoid
    end

    setMenuVisibility(true)
    setBlurEnabled(true)

    if Spectate.lastLabel then
        Spectate.lastLabel.TextColor3 = Spectate.DEFAULT_COLOR
        Spectate.lastLabel = nil
    end

    if Spectate.currentTarget then
        Notifier.new({ Title = "Spectate", Content = "Stopped spectating: " .. Spectate.currentTarget, Duration = 2 })
    end

    Spectate.currentTarget = nil
    Spectate.lastTemplate  = nil
end

local function cycleSpectate(direction)
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then table.insert(list, p) end
    end
    if #list == 0 then return end

    if not Spectate.currentTarget then
        spectatePlayer(list[1].Name)
        return
    end

    local idx = nil
    for i, p in ipairs(list) do
        if p.Name == Spectate.currentTarget then idx = i; break end
    end

    local nextIdx = ((( idx or 1) - 1 + direction) % #list) + 1

    if Spectate.lastLabel then
        Spectate.lastLabel.TextColor3 = Spectate.DEFAULT_COLOR
        Spectate.lastLabel = nil
        Spectate.lastTemplate = nil
    end

    spectatePlayer(list[nextIdx].Name)
end

-- In-game PlayerList click hook --
local function connectTemplateClick(template)
    -- Guard: never attach more than one handler to the same template object
    if Spectate.connectedTemplates[template] then return end
    Spectate.connectedTemplates[template] = true

    local conn = template.MouseButton1Click:Connect(function()
        local nameLabel = template:FindFirstChild("PlayerName")
        if not nameLabel then return end

        -- Resolve actual player name (label text may have clan/level prefixes)
        local labelText = nameLabel.Text
        local resolvedName = nil
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name == labelText or labelText:find(p.Name, 1, true) then
                resolvedName = p.Name
                break
            end
        end
        if not resolvedName then return end

        -- Stop spectating if already watching this player
        if Spectate.currentTarget == resolvedName then
            stopSpectating()
            return
        end

        if Spectate.lastLabel then
            Spectate.lastLabel.TextColor3 = Spectate.DEFAULT_COLOR
        end

        spectatePlayer(resolvedName)
        Spectate.lastTemplate    = template
        nameLabel.TextColor3     = Spectate.HIGHLIGHT_COLOR
        Spectate.lastLabel       = nameLabel

        -- Re-apply red highlight every 0.25s in case the game resets it
        task.spawn(function()
            while Spectate.currentTarget == resolvedName do
                pcall(function()
                    if nameLabel.TextColor3 ~= Spectate.HIGHLIGHT_COLOR then
                        nameLabel.TextColor3 = Spectate.HIGHLIGHT_COLOR
                    end
                end)
                task.wait(0.25)
            end
        end)
    end)
    table.insert(Spectate.connections, conn)
end

local function setupSpectateHooks()
    for _, c in ipairs(Spectate.connections) do pcall(function() c:Disconnect() end) end
    Spectate.connections        = {}
    Spectate.connectedTemplates = {}

    pcall(function()
        local list = LocalPlayer
            :WaitForChild("PlayerGui",   10)
            :WaitForChild("ClientGui",   10)
            :WaitForChild("Mainframe",   10)
            :WaitForChild("PlayerList",  10)
            :WaitForChild("List",        10)

        for _, t in ipairs(list:GetChildren()) do
            if t:IsA("ImageButton") and t.Name == "PlayerTemplate" then
                connectTemplateClick(t)
            end
        end

        table.insert(Spectate.connections, list.ChildAdded:Connect(function(child)
            if child:IsA("ImageButton") and child.Name == "PlayerTemplate" then
                task.wait(0.1)
                connectTemplateClick(child)
            end
        end))
    end)
end

-- Try to hook the PlayerList as soon as it exists, retrying every 0.5s --
task.spawn(function()
    for _ = 1, 20 do
        task.wait(0.5)
        setupSpectateHooks()
        if #Spectate.connections > 0 then break end
    end
end)

