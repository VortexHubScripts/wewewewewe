    local pick = obj:FindFirstChild("Pickupable")
    return pick and pick:IsA("StringValue")
end

local function createGrabESP(obj)
    if otherGrabObjects[obj] then return end
    otherGrabObjects[obj] = newESPText(Color3.fromRGB(255, 220, 50))
end

local function destroyGrabESP(obj)
    local t = otherGrabObjects[obj]
    if not t then return end
    t:Remove(); otherGrabObjects[obj] = nil
end

local function isInPlayerCharacter(obj)
    local ancestor = obj.Parent
    while ancestor and ancestor ~= workspace do
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character == ancestor then return true end
        end
        ancestor = ancestor.Parent
    end
    return false
end

