local function randomServerHop()
    local serversFolder = ReplicatedStorage:FindFirstChild("Servers")
    if not serversFolder then
        Notifier.new({ Title = "Server Hop", Content = "Servers folder not found.", Duration = 4 })
        return
    end

    local serverList = {}
    for _, child in pairs(serversFolder:GetChildren()) do
        if child:IsA("StringValue") and child.Value ~= "" then
            local serverId, playerCount = child.Value:match("^(%S+)%s+(%d+)$")
            if serverId and playerCount then
                local count = tonumber(playerCount) or 0
                if count >= 10 and count <= 19 then
                    table.insert(serverList, { name = child.Name, id = serverId, playerCount = count })
                end
            end
        end
    end

    if #serverList == 0 then
        Notifier.new({ Title = "Server Hop", Content = "No suitable servers found.", Duration = 4 })
        return
    end

    local selected = serverList[math.random(1, #serverList)]
    Notifier.new({ Title = "Server Hop", Content = string.format('Joining "%s" (%d players)', selected.name, selected.playerCount), Duration = 4 })
    ReplicatedStorage.Events.DataEvent:FireServer("ServerTeleport", selected.id, 14)
end

local function lowPlayerServerHop()
    local serversFolder = ReplicatedStorage:FindFirstChild("Servers")
    if not serversFolder then
        Notifier.new({ Title = "Server Hop", Content = "Servers folder not found.", Duration = 4 })
        return
    end

    local currentJobId = game.JobId
    local serverList = {}
    for _, child in pairs(serversFolder:GetChildren()) do
        if child:IsA("StringValue") and child.Value ~= "" then
            local serverId, playerCount = child.Value:match("^(%S+)%s+(%d+)$")
            if serverId and playerCount then
                local count = tonumber(playerCount) or 0
                if count >= 1 and count < 10 and serverId ~= currentJobId then
                    table.insert(serverList, { name = child.Name, id = serverId, playerCount = count })
                end
            end
        end
    end

    if #serverList == 0 then
        Notifier.new({ Title = "Server Hop", Content = "No servers found with under 10 players.", Duration = 4 })
        return
    end

    table.sort(serverList, function(a, b) return a.playerCount < b.playerCount end)
    local selected = serverList[math.random(1, math.min(3, #serverList))]
    Notifier.new({ Title = "Server Hop", Content = string.format('Joining "%s" (%d players)', selected.name, selected.playerCount), Duration = 4 })
    ReplicatedStorage.Events.DataEvent:FireServer("ServerTeleport", selected.id, 14)
end

