        return fruitVisitedSets[fruitName]
    end

    local function getFruitInstances(fruitName)
        local raw = {}
        local v1 = fruitName
        local v2 = fruitName:gsub(" ", "_")
        for _, child in ipairs(workspace:GetChildren()) do
            if child:IsA("BasePart") and (child.Name == v1 or child.Name == v2) then
                table.insert(raw, child)
            end
        end
        for _, child in ipairs(ReplicatedStorage:GetChildren()) do
            if child:IsA("BasePart") and (child.Name == v1 or child.Name == v2) then
                table.insert(raw, child)
            end
        end
        -- Deduplicate by position (round to 1 decimal to absorb float noise)
        local seen     = {}
        local instances = {}
        for _, obj in ipairs(raw) do
            local p   = obj.Position
            local key = math.round(p.X * 10) .. "," .. math.round(p.Y * 10) .. "," .. math.round(p.Z * 10)
            if not seen[key] then
                seen[key] = true
                table.insert(instances, obj)
            end
        end
        return instances
    end

    local FRUIT_PLURAL = {
        ["Chakra Fruit"]           = "Chakra Fruits",
        ["Life Up Fruit"]          = "Life Up Fruits",
        ["Fruit Of Forgetfulness"] = "Fruits Of Forgetfulness",
    }

    local function teleportToFruitType(fruitName, showCounter)
        local instances = getFruitInstances(fruitName)
        local visited   = getFruitVisited(fruitName)
        local total     = #instances

        local candidates = {}
        for _, obj in ipairs(instances) do
            if not visited[obj] then
                if not nearbyPlayerExists(obj.Position, 50) then
                    table.insert(candidates, obj)
                end
            end
        end

        local plural = FRUIT_PLURAL[fruitName] or (fruitName .. "s")

        if #candidates == 0 then
            Notifier.new({ Title = fruitName .. " TP", Content = "No available " .. plural .. " found!", Duration = 4 })
            return
        end

        local chosen = candidates[math.random(1, #candidates)]
        visited[chosen] = true
        teleportTo(chosen.Position)

        if showCounter then
            local visitedCount = 0
            for _ in pairs(visited) do visitedCount = visitedCount + 1 end
            Notifier.new({ Title = fruitName .. " TP", Content = visitedCount .. "/" .. total .. " " .. plural .. " Left", Duration = 4 })
        else
            Notifier.new({ Title = "Teleport", Content = "Teleported to " .. fruitName, Duration = 3 })
        end
    end

