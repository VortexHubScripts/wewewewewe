-- Auto Sell --
local function sellAll(item)
    Notifier:notify({ Title = "Auto Sell", Content = "Attempting to sell " .. item .. "s...", Duration = 2 })

    local ok, err = pcall(function()
        -- Search all common module sources
        local sources = {}
        if getrenv then table.insert(sources, getrenv()) end
        if getgenv  then table.insert(sources, getgenv())  end
        table.insert(sources, _G)
        if shared   then table.insert(sources, shared)     end

        local Common, Utils, Databases
        for _, src in ipairs(sources) do
            Common    = Common    or rawget(src, "Common")
            Utils     = Utils     or rawget(src, "Utils")
            Databases = Databases or rawget(src, "Databases")
            if Common and Utils and Databases then break end
        end

        if not Common or not Utils or not Databases then
            Notifier:notify({ Title = "Auto Sell", Content = "Game modules not found", Duration = 4 })
            return
        end

        local plrData   = Utils.getPlrData()
        local bulkPrice = Common.GameManager:calculateBulk(plrData.Inventory, plrData.Loadout, item, nil, "Sale")
        local villages  = { "Sorythia", "Durana", "Rain", "none" }

        if not bulkPrice then
            Notifier:notify({ Title = "Auto Sell", Content = "Nothing to sell", Duration = 3 })
            return
        end

        local offeredPrices = {}
        for _, v in ipairs(villages) do
            local price
            if v == "none" then
                price = bulkPrice
            else
                price = Common.GameManager:getModifiedPrice(
                    bulkPrice,
                    Utils.getVillageRelations(plrData.Village, v),
                    Utils.getEconomy(v),
                    "Sell"
                )
            end
            table.insert(offeredPrices, { village = v, price = price })
        end

        table.sort(offeredPrices, function(a, b) return a.price > b.price end)
        Databases.NPCs.bestVillage = offeredPrices[1].village

        if item == "Fruit" then
            local BEST = Databases.NPCs.Fruit[Databases.NPCs.bestVillage]
            Common.DataFunction:InvokeServer("SellingBulk", offeredPrices[1].price, "Fruit", "Fish", BEST)
        else
            local BEST = Databases.NPCs.Trinket[Databases.NPCs.bestVillage]
            Common.DataFunction:InvokeServer("SellingBulk", offeredPrices[1].price, item, BEST)
        end

        Notifier:notify({ Title = "Auto Sell", Content = "Sold all " .. item .. "s", Duration = 2 })
    end)

    if not ok then
        Notifier:notify({ Title = "Auto Sell Error", Content = tostring(err), Duration = 6 })
    end
end

