local function setBoxVisible(box, v)
    for _, l in ipairs(box) do l.Visible = v end
end

local function setBoxColor(box, c)
    for _, l in ipairs(box) do l.Color = c end
end

local function drawBox(box, tl, tr, bl, br)
    box[1].From = tl; box[1].To = tr  -- top edge
    box[2].From = bl; box[2].To = br  -- bottom edge
    box[3].From = tl; box[3].To = bl  -- left edge
    box[4].From = tr; box[4].To = br  -- right edge
    for _, l in ipairs(box) do l.Visible = true end
end

-- ════ Per-player ESP lifecycle ════ --

local function getESPColor(player)
    if ESPSettings.VillageColor and player.Team then
        return player.Team.TeamColor.Color
    end
    return ESPSettings.Color
end

local function createPlayerESP(player)
    if player == LocalPlayer or playerESPObjects[player] then return end

    local conns = {}
    local cache = {
        bloodline = "", awakened = "", awakeningCooldown = 0,
        combatTimer = 0, blood = 0,
    }

    -- ── Settings watchers (Bloodline, Awakened, AwakeningCooldown) ──
    -- Wrapped in a function so it can be re-called on respawn in case the server recreates folders
    local function hookSettings()
        local settingsRoot = ReplicatedStorage:FindFirstChild("Settings")
        if not settingsRoot then return end
        local ps = settingsRoot:FindFirstChild(player.Name)
        if not ps then
            -- Watch for the folder to appear later
            table.insert(conns, settingsRoot.ChildAdded:Connect(function(child)
                if child.Name == player.Name then
                    task.wait(0.1)
                    hookSettings()
                end
            end))
            return
        end
        local bl = ps:FindFirstChild("Bloodline")
        if bl then
            cache.bloodline = tostring(bl.Value)
            table.insert(conns, bl:GetPropertyChangedSignal("Value"):Connect(function()
                cache.bloodline = tostring(bl.Value)
            end))
        end
        local aw = ps:FindFirstChild("Awakened")
        if aw then
            cache.awakened = tostring(aw.Value)
            table.insert(conns, aw:GetPropertyChangedSignal("Value"):Connect(function()
                cache.awakened = tostring(aw.Value)
            end))
        end
        local awc = ps:FindFirstChild("AwakeningCooldown")
        if awc then
            cache.awakeningCooldown = awc.Value or 0
            table.insert(conns, awc:GetPropertyChangedSignal("Value"):Connect(function()
                cache.awakeningCooldown = awc.Value or 0
            end))
        end
    end
    hookSettings()

    -- ── Combat Timer ──
    local combatRoot = ReplicatedStorage:FindFirstChild("CombatTags")
    if combatRoot then
        local function hookCombat(folder)
            local function refreshTimer()
                local hi = 0
                for _, v in ipairs(folder:GetChildren()) do
                    if v:IsA("NumberValue") and v.Value > hi then hi = v.Value end
                end
                cache.combatTimer = hi
            end
            for _, v in ipairs(folder:GetChildren()) do
                if v:IsA("NumberValue") then
                    table.insert(conns, v:GetPropertyChangedSignal("Value"):Connect(refreshTimer))
                end
            end
            table.insert(conns, folder.ChildAdded:Connect(function(v)
                if v:IsA("NumberValue") then
                    task.wait()
                    refreshTimer()  -- immediate read when combat tag appears
                    table.insert(conns, v:GetPropertyChangedSignal("Value"):Connect(refreshTimer))
                end
            end))
            table.insert(conns, folder.ChildRemoved:Connect(function()
                task.wait()
                refreshTimer()  -- refresh when combat tag is removed
            end))
            refreshTimer()
        end
        local pf = combatRoot:FindFirstChild(player.Name)
        if pf then
            hookCombat(pf)
        else
            table.insert(conns, combatRoot.ChildAdded:Connect(function(child)
                if child.Name == player.Name then
                    task.wait(0.1)
                    hookCombat(child)
                end
            end))
        end
    end

    -- ── Blood (re-hook on respawn) ──
    local function hookBlood()
        local bp = player:FindFirstChild("Backpack")
        if not bp then return end
        local bv = bp:FindFirstChild("blood")
        if not bv then return end
        cache.blood = bv.Value
        table.insert(conns, bv:GetPropertyChangedSignal("Value"):Connect(function()
            cache.blood = bv.Value
        end))
    end
    hookBlood()
    table.insert(conns, player.CharacterAdded:Connect(function()
        task.wait(1)
        hookBlood()
        hookSettings()  -- re-hook in case server recreated the settings folder
    end))

    playerESPObjects[player] = {
        mainText     = newESPText(),
        awakenedText = newESPText(ESP_COLOR_AWAKENED),
        jutsuText    = newESPText(ESP_COLOR_JUTSU),
        distanceText = newESPText(),
        box          = newESPBox(),
        healthBarBG  = newESPHealthBar(),
        healthBar    = newESPHealthBar(),
        conns        = conns,
        cache        = cache,
    }
end

local function destroyPlayerESP(player)
    local data = playerESPObjects[player]
    if not data then return end
    data.mainText:Remove()
    data.awakenedText:Remove()
    data.jutsuText:Remove()
    data.distanceText:Remove()
    setBoxVisible(data.box, false)
    for _, l in ipairs(data.box) do l:Remove() end
    data.healthBarBG:Remove()
    data.healthBar:Remove()
    for _, c in ipairs(data.conns) do pcall(function() c:Disconnect() end) end
    local n = player.Name
    if jutsuConnections[n] then
        for _, c in pairs(jutsuConnections[n]) do pcall(function() c:Disconnect() end) end
        jutsuConnections[n] = nil
    end
    playerJutsuData[n] = nil
    playerESPObjects[player] = nil
end

local function destroyAllPlayerESP()
    for p in pairs(playerESPObjects) do destroyPlayerESP(p) end
end

-- ════ Render loop ════ --

local espRenderConn = nil

local function startESPLoop()
    if espRenderConn then return end
    espRenderConn = RunService.RenderStepped:Connect(function()
        if not ESPSettings.Enabled then return end
        local camera   = workspace.CurrentCamera
        local camPos   = camera.CFrame.Position
        local show     = ESPSettings.Show
        local textSize = ESPSettings.TextSize
        local textFont = ESPSettings.TextFont

        for player, data in pairs(playerESPObjects) do
            local char     = player.Character
            local hrp      = char and char:FindFirstChild("HumanoidRootPart")
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")

            if not hrp or not humanoid or humanoid.Health <= 0 then
                data.mainText.Visible     = false
                data.awakenedText.Visible = false
                data.jutsuText.Visible    = false
                data.distanceText.Visible = false
                setBoxVisible(data.box, false)
                data.healthBarBG.Visible  = false
                data.healthBar.Visible    = false
                continue
            end

            local worldPos         = hrp.Position
            local dist             = (worldPos - camPos).Magnitude
            local sp, onScreen     = camera:WorldToViewportPoint(worldPos + Vector3.new(0, 3.2, 0))

            if not onScreen then
                data.mainText.Visible     = false
                data.awakenedText.Visible = false
                data.jutsuText.Visible    = false
                data.distanceText.Visible = false
                setBoxVisible(data.box, false)
                data.healthBarBG.Visible  = false
                data.healthBar.Visible    = false
                continue
            end

            local color = getESPColor(player)
            local cache = data.cache
            local cx    = sp.X
            local baseY = sp.Y

            -- Apply live text properties --
            data.mainText.Size     = textSize
            data.awakenedText.Size = textSize
            data.jutsuText.Size    = textSize
            data.distanceText.Size = textSize
            data.mainText.Font     = textFont
            data.awakenedText.Font = textFont
            data.jutsuText.Font    = textFont
            data.distanceText.Font = textFont

            local textVisible = dist <= ESPSettings.TextDistance

            -- Pre-compute box screen coords (shared by box, health bar, and distance text) --
            local sz    = ESPSettings.BoxSize
            local topSP = camera:WorldToViewportPoint(worldPos + Vector3.new(0,  2.8 * sz, 0))
            local botSP = camera:WorldToViewportPoint(worldPos + Vector3.new(0, -2.8 * sz, 0))
            local boxH  = math.abs(botSP.Y - topSP.Y)
            local boxW  = boxH * 0.35
            local boxVisible = ESPSettings.BoxEnabled and dist <= ESPSettings.BoxDistance

            -- ── Main line: Name | HP HP | Bloodline | Reanimated | Freshy | CTs | Blood% ──
            local parts = {}
            if show.Name then
                table.insert(parts, player.Name)
            end
            if show.Health then
                table.insert(parts, string.format("%d/%d HP", math.floor(humanoid.Health), math.floor(humanoid.MaxHealth)))
            end
            if show.Bloodline and cache.bloodline ~= "" then
                table.insert(parts, cache.bloodline)
            end
            if show.ShowReanimated and char:GetAttribute("Reanimated") then
                table.insert(parts, "Reanimated")
            end
            if show.FreshyChecker then
                local dn = humanoid.DisplayName
                if dn and dn:find("🌱", 1, true) then
                    table.insert(parts, "Freshy")
                end
            end
            if show.ShowBlood then
                table.insert(parts, math.floor(cache.blood) .. "%")
            end
            if show.ShowCombatTimer and cache.combatTimer > 1 then
                table.insert(parts, math.floor(cache.combatTimer) .. "s")
            end

            if textVisible and #parts > 0 then
                data.mainText.Text     = table.concat(parts, " | ")
                data.mainText.Position = Vector2.new(cx, baseY)
                data.mainText.Color    = color
                data.mainText.Visible  = true
            else
                data.mainText.Visible = false
            end

            -- ── Awakened line: [Form] [Xs] in purple, one line above main ──
            local awakenedStr     = cache.awakened
            local hasForm         = awakenedStr ~= "" and awakenedStr ~= "false" and awakenedStr ~= "nil"
            local hasCooldown     = cache.awakeningCooldown and cache.awakeningCooldown > 0
            local showAwakened    = show.ShowAwakened and (hasForm or hasCooldown)
            if showAwakened and textVisible then
                local awakenedDisplay
                if hasForm then
                    awakenedDisplay = "[" .. awakenedStr .. "]"
                    if hasCooldown then
                        awakenedDisplay = awakenedDisplay .. " [" .. math.floor(cache.awakeningCooldown) .. "s]"
                    end
                else
                    awakenedDisplay = "[" .. math.floor(cache.awakeningCooldown) .. "s]"
                end
                data.awakenedText.Text     = awakenedDisplay
                data.awakenedText.Position = Vector2.new(cx, baseY - ESP_LINE_HEIGHT)
                data.awakenedText.Visible  = true
            else
                data.awakenedText.Visible = false
                showAwakened = false
            end

            -- ── Jutsu line (yellow, above awakened or main) ──
            local jutsuOffset = showAwakened and (ESP_LINE_HEIGHT * 2) or ESP_LINE_HEIGHT
            if show.JutsuPrediction and textVisible then
                local jd = playerJutsuData[player.Name]
                if jd and jd.activeJutsu and (tick() - jd.lastUpdate) < 5 then
                    data.jutsuText.Text     = "[" .. jd.activeJutsu .. "]"
                    data.jutsuText.Position = Vector2.new(cx, baseY - jutsuOffset)
                    data.jutsuText.Visible  = true
                else
                    data.jutsuText.Visible = false
                end
            else
                data.jutsuText.Visible = false
            end

            -- ── Box ESP ──
            if boxVisible then
                drawBox(data.box,
                    Vector2.new(cx - boxW, topSP.Y), Vector2.new(cx + boxW, topSP.Y),
                    Vector2.new(cx - boxW, botSP.Y), Vector2.new(cx + boxW, botSP.Y))
                setBoxColor(data.box, color)
            else
                setBoxVisible(data.box, false)
            end

            -- ── Health Bar (vertical filled bar, left of box) ──
            if show.HealthBar then
                local hpRatio  = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
                local barColor = Color3.fromRGB(
                    math.floor(255 * (1 - hpRatio)),
                    math.floor(255 * hpRatio),
                    0
                )
                local bw     = ESPSettings.HealthBarWidth
                local barX   = cx - boxW - bw - 3
                local fillH  = math.max(1, boxH * hpRatio)

                data.healthBarBG.Size     = Vector2.new(bw, boxH)
                data.healthBarBG.Position = Vector2.new(barX, topSP.Y)
                data.healthBarBG.Color    = Color3.fromRGB(40, 40, 40)
                data.healthBarBG.Visible  = true

                data.healthBar.Size     = Vector2.new(bw, fillH)
                data.healthBar.Position = Vector2.new(barX, botSP.Y - fillH)
                data.healthBar.Color    = barColor
                data.healthBar.Visible  = true
            else
                data.healthBarBG.Visible = false
                data.healthBar.Visible   = false
            end

            -- ── Distance text (below box when box visible, else below main text) ──
            if show.Distance and textVisible then
                local distY = boxVisible and (botSP.Y + 4) or (baseY + ESP_LINE_HEIGHT)
                data.distanceText.Text     = string.format("%.0fm", dist)
                data.distanceText.Position = Vector2.new(cx, distY)
                data.distanceText.Color    = color
                data.distanceText.Visible  = true
            else
                data.distanceText.Visible = false
            end
        end
    end)
end

local function stopESPLoop()
    if espRenderConn then espRenderConn:Disconnect(); espRenderConn = nil end
end

local function setPlayerESP(enabled)
    ESPSettings.Enabled = enabled
    if enabled then
        for _, p in ipairs(Players:GetPlayers()) do createPlayerESP(p) end
        if ESPSettings.Show.JutsuPrediction then initJutsuPrediction() end
        startESPLoop()
    else
        destroyAllPlayerESP()
        stopESPLoop()
    end
end

Players.PlayerAdded:Connect(function(p)
    if ESPSettings.Enabled then createPlayerESP(p) end
end)
Players.PlayerRemoving:Connect(function(p)
    destroyPlayerESP(p)
end)

