local function startOtherESPLoop()
    if otherRenderConn then return end
    otherRenderConn = RunService.RenderStepped:Connect(function()
        local camera   = workspace.CurrentCamera
        local camPos   = camera.CFrame.Position
        local textSize = OtherESPSettings.TextSize
        local textFont = ESPSettings.TextFont
        local maxDist  = OtherESPSettings.TextDistance

        local function renderTable(tbl, enabled, destroyFn, textFn, shouldRemoveFn)
            local toClean = {}
            for obj, label in pairs(tbl) do
                if not obj.Parent or (shouldRemoveFn and shouldRemoveFn(obj)) then
                    label.Visible = false
                    table.insert(toClean, obj)
                    continue
                end
                if not enabled then label.Visible = false; continue end
                local pos = getObjPos(obj)
                if not pos then label.Visible = false; continue end
                local dist = (pos - camPos).Magnitude
                local sp, onScreen = camera:WorldToViewportPoint(pos + Vector3.new(0, 2, 0))
                if not onScreen or dist > maxDist then label.Visible = false; continue end
                label.Size     = textSize
                label.Font     = textFont
                label.Text     = textFn and textFn(obj, dist) or string.format("%s  %.0fm", obj.Name, dist)
                label.Position = Vector2.new(sp.X, sp.Y)
                label.Visible  = true
            end
            for _, o in ipairs(toClean) do destroyFn(o) end
        end

        renderTable(otherNPCObjects,    OtherESPSettings.NPC,         destroyNPCESP)
        renderTable(otherGrabObjects,   OtherESPSettings.Grabable,    destroyGrabESP)
        renderTable(otherWeaponObjects, OtherESPSettings.Weapon,      destroyWeaponESP)
        renderTable(otherEventWObjects, OtherESPSettings.EventWeapon, destroyEventWeaponESP)
        renderTable(otherRiftObjects, OtherESPSettings.Rift, destroyRiftESP, function(obj, dist)
            local id = obj:GetAttribute("ID")
            return string.format("%s [%s]\n%.0fm", obj.Name, tostring(id or "?"), dist)
        end)
        renderTable(otherChakraObjects, OtherESPSettings.Chakra, destroyChakraESP, function(obj, dist)
            local pnVal = obj:FindFirstChild("PointName")
            local ulVal = obj:FindFirstChild("Unlocked")
            local name  = (pnVal and pnVal.Value ~= "") and pnVal.Value or obj.Name
            local tag   = (ulVal and ulVal.Value == false) and " [X]" or ""
            return string.format("%s%s\n%.0fm", name, tag, dist)
        end)
        renderTable(otherCorruptedObjects, OtherESPSettings.Corrupted, destroyCorruptedESP, function(obj, dist)
            local hVal   = obj:FindFirstChild("Health")
            local hp     = math.floor(100 - (hVal and hVal.Value or 0))
            return string.format("%s [%d/100]\n%.0fm", obj.Name, hp, dist)
        end, function(obj)
            local d = obj:FindFirstChild("Destroyed")
            return d and d:IsA("BoolValue") and d.Value == true
        end)
    end)
end

local function stopOtherESPLoop()
    if otherRenderConn then otherRenderConn:Disconnect(); otherRenderConn = nil end
end

local function isAnyOtherESPEnabled()
    return OtherESPSettings.NPC or OtherESPSettings.Grabable
        or OtherESPSettings.Weapon or OtherESPSettings.EventWeapon
        or OtherESPSettings.Rift or OtherESPSettings.Chakra
        or OtherESPSettings.Corrupted
end

local function hookOtherDescendants()
    if otherDescConn then otherDescConn:Disconnect() end
    otherDescConn = workspace.DescendantAdded:Connect(function(obj)
        task.wait()
        if OtherESPSettings.NPC         and isDialogNPC(obj)                        then createNPCESP(obj)         end
        if OtherESPSettings.Grabable    and isGrabable(obj)                          then createGrabESP(obj)        end
        if OtherESPSettings.Weapon      and isTopLevelNamed(obj, WEAPON_NAMES)       then createWeaponESP(obj)      end
        if OtherESPSettings.EventWeapon and isTopLevelNamed(obj, EVENT_WEAPON_NAMES) then createEventWeaponESP(obj) end
        if OtherESPSettings.Rift        and isRift(obj)                              then createRiftESP(obj)        end
        if OtherESPSettings.Chakra      and isChakraPoint(obj)                       then createChakraESP(obj)      end
        if OtherESPSettings.Corrupted   and isCorruptedPoint(obj)                    then createCorruptedESP(obj)   end
    end)
end

local function updateOtherHooks()
    if isAnyOtherESPEnabled() then
        hookOtherDescendants()
        startOtherESPLoop()
    else
        if otherDescConn then otherDescConn:Disconnect(); otherDescConn = nil end
        stopOtherESPLoop()
    end
end

