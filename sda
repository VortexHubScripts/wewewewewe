    if not (obj:IsA("Part") or obj:IsA("MeshPart") or obj:IsA("Model")) then return false end
    if isInPlayerCharacter(obj) then return false end
    local par = obj.Parent
    if par and (par:IsA("Part") or par:IsA("MeshPart") or par:IsA("Model")) and nameSet[par.Name] then
        return false
    end
    return true
end

