local function newESPText(color)
    local t = Drawing.new("Text")
    t.Visible  = false
    t.Color    = color or Color3.fromRGB(255, 255, 255)
    t.Size     = 16
    t.Font     = 0  -- Legacy     default
    t.Outline  = true
    t.Center   = true
    return t
end

local ESP_COLOR_JUTSU    = Color3.fromRGB(255, 220, 50)   -- yellow
local ESP_COLOR_AWAKENED = Color3.fromRGB(180, 80, 255)   -- purple
local ESP_LINE_HEIGHT    = 16

local DrawingFonts = {
    ["Legacy"]      = 0,
    ["System"]      = 1,
