    local cooldownsFolder = ReplicatedStorage:FindFirstChild("Cooldowns")
    if not cooldownsFolder then return end
    local playerFolder = cooldownsFolder:FindFirstChild(playerName)
    if not playerFolder then return end

    if jutsuConnections[playerName] then
        for _, c in pairs(jutsuConnections[playerName]) do pcall(function() c:Disconnect() end) end
    end
    jutsuConnections[playerName] = {}

    local function watchAbility(child)
        local name = child.Name
        -- only fire on actual value changes, never on initial read
        local conn = child:GetPropertyChangedSignal("Value"):Connect(function()
            if child.Value > 0 then
                playerJutsuData[playerName].activeJutsu = name
                playerJutsuData[playerName].lastUpdate = tick()
            end
        end)
        table.insert(jutsuConnections[playerName], conn)
    end

    for _, child in pairs(playerFolder:GetChildren()) do
        if child:IsA("NumberValue") then watchAbility(child) end
    end

    local addedConn = playerFolder.ChildAdded:Connect(function(child)
        if child:IsA("NumberValue") then
            task.wait()
            watchAbility(child)
        end
    end)
    table.insert(jutsuConnections[playerName], addedConn)
end

local function initJutsuPrediction()
    local cooldownsFolder = ReplicatedStorage:FindFirstChild("Cooldowns")
    if not cooldownsFolder then return end

    for _, folder in pairs(cooldownsFolder:GetChildren()) do
        if folder:IsA("Folder") and folder.Name ~= LocalPlayer.Name then
            setupJutsuPrediction(folder.Name)
        end
    end

    cooldownsFolder.ChildAdded:Connect(function(folder)
        if folder:IsA("Folder") and folder.Name ~= LocalPlayer.Name then
            task.wait(0.1)
            setupJutsuPrediction(folder.Name)
        end
    end)

    cooldownsFolder.ChildRemoved:Connect(function(folder)
        local n = folder.Name
        if jutsuConnections[n] then
            for _, c in pairs(jutsuConnections[n]) do pcall(function() c:Disconnect() end) end
            jutsuConnections[n] = nil
        end
        playerJutsuData[n] = nil
    end)
end

