        originalFogEnd = Lighting.FogEnd
        Lighting.FogEnd = 99999
    else
        Lighting.FogEnd = originalFogEnd
    end
end

-- No Rain --
local noRainLoop = false

local function setNoRain(enabled)
    noRainLoop = enabled
    if enabled then
        task.spawn(function()
            while noRainLoop do
                pcall(function()
                    ReplicatedStorage.Raining.Value = ""
                end)
                task.wait(0.5)
            end
        end)
    end
end

-- Full Bright --
local originalBrightness = Lighting.Brightness
local fullBrightEnabled = false
local currentBrightnessLevel = 5

local function applyFullBright()
    if fullBrightEnabled then
        Lighting.Brightness = currentBrightnessLevel
    end
end

local function setFullBright(enabled)
    fullBrightEnabled = enabled
    if enabled then
        originalBrightness = Lighting.Brightness
        applyFullBright()
    else
        Lighting.Brightness = originalBrightness
    end
end

-- Time Changer --
-- Hooks ClockTime's changed signal to revert it immediately whenever the game updates it --
local timeChangerEnabled = false
local currentTimeOfDay = "Morning"
local blockingClockTime = false

Lighting:GetPropertyChangedSignal("ClockTime"):Connect(function()
    if timeChangerEnabled and not blockingClockTime then
        blockingClockTime = true
        Lighting.ClockTime = ClockTimes[currentTimeOfDay] or 6.3
        blockingClockTime = false
    end
end)

local function setTimeChanger(enabled)
    timeChangerEnabled = enabled
    if enabled then
        blockingClockTime = true
        Lighting.ClockTime = ClockTimes[currentTimeOfDay] or 6.3
        blockingClockTime = false
    end
end

