    end

    task.spawn(function()
        local count = 0
        for _, obj in ipairs(workspace:GetDescendants()) do
            if not treeJumpEnabled then break end
            if obj:GetAttribute("CanTreeJump") == nil then
                pcall(function()
                    obj:SetAttribute("CanTreeJump", true)
                    table.insert(treeJumpAdded, obj)
                end)
            end
            count += 1
            if count % 200 == 0 then task.wait() end
        end
    end)
end

-- Infinite Jump Counter --
local infinitestamina = false
local infiniteStaminaHooked = false

local function setupInfiniteStamina()
    if infiniteStaminaHooked then return end
    infiniteStaminaHooked = true

    local infjumps
    infjumps = hookmetamethod(game, "__namecall", function(self, ...)
        local args = { ... }
        local method = getnamecallmethod()
        if tostring(self) == "DataEvent" and method == "FireServer" then
            if args[1] == "Jump" and infinitestamina then
                return nil
            end
        end
        return infjumps(self, unpack(args))
    end)
end

local function infiniteJumpCounter(state)
    infinitestamina = state
    if state and not infiniteStaminaHooked then
        setupInfiniteStamina()
    end
end

