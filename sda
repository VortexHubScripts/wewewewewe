local MobESPSettings = {
    Enabled      = false,
    Show = {
        Name     = true,
        Health   = true,
        Distance = true,
    },
    Color        = Color3.fromRGB(255, 100, 100),
    TextSize     = 14,
    TextDistance = 1000,
}

local mobESPObjects = {}  -- [Model] = { mainText, distanceText }
local mobRenderConn = nil
local mobDescConn   = nil

local function isMobModel(model)
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character == model then return false end
    end
    local npc = model:FindFirstChild("NPC")
    if npc and npc:IsA("StringValue") and npc.Value == "Combat" then
        return true
    end
    local wb = model:FindFirstChild("WorldBoss")
    if wb and wb:IsA("BoolValue") then
        return true
    end
    return false
end

local function createMobESP(model)
    if mobESPObjects[model] then return end
    local humanoid = model:FindFirstChildOfClass("Humanoid")
    local hrp      = model:FindFirstChild("HumanoidRootPart")
    if not humanoid or not hrp then return end
    mobESPObjects[model] = {
        mainText     = newESPText(MobESPSettings.Color),
        distanceText = newESPText(MobESPSettings.Color),
    }
end

local function destroyMobESP(model)
    local data = mobESPObjects[model]
    if not data then return end
    data.mainText:Remove()
    data.distanceText:Remove()
    mobESPObjects[model] = nil
end

local function destroyAllMobESP()
    for m in pairs(mobESPObjects) do destroyMobESP(m) end
end

local function startMobESPLoop()
    if mobRenderConn then return end
    mobRenderConn = RunService.RenderStepped:Connect(function()
        if not MobESPSettings.Enabled then return end
        local camera   = workspace.CurrentCamera
        local camPos   = camera.CFrame.Position
        local show     = MobESPSettings.Show
        local textSize = MobESPSettings.TextSize
        local textFont = ESPSettings.TextFont  -- shared with player ESP
        local color    = MobESPSettings.Color

        local toCleanup = {}
        for model, data in pairs(mobESPObjects) do
            if not model.Parent then
                table.insert(toCleanup, model)
                data.mainText.Visible     = false
                data.distanceText.Visible = false
                continue
            end

            local humanoid = model:FindFirstChildOfClass("Humanoid")
            local hrp      = model:FindFirstChild("HumanoidRootPart")

            if not hrp or not humanoid or humanoid.Health <= 0 then
                data.mainText.Visible     = false
                data.distanceText.Visible = false
                continue
            end

            local worldPos     = hrp.Position
            local dist         = (worldPos - camPos).Magnitude
            local sp, onScreen = camera:WorldToViewportPoint(worldPos + Vector3.new(0, 3.2, 0))

            if not onScreen or dist > MobESPSettings.TextDistance then
                data.mainText.Visible     = false
                data.distanceText.Visible = false
                continue
            end

            data.mainText.Size      = textSize
            data.mainText.Font      = textFont
            data.mainText.Color     = color
            data.distanceText.Size  = textSize
            data.distanceText.Font  = textFont
            data.distanceText.Color = color

            local cx    = sp.X
            local baseY = sp.Y

            local parts = {}
            if show.Name then
                table.insert(parts, model.Name)
            end
            if show.Health then
                table.insert(parts, string.format("%d/%d HP", math.floor(humanoid.Health), math.floor(humanoid.MaxHealth)))
            end

            if #parts > 0 then
                data.mainText.Text     = table.concat(parts, " | ")
                data.mainText.Position = Vector2.new(cx, baseY)
                data.mainText.Visible  = true
            else
                data.mainText.Visible = false
            end

            if show.Distance then
                data.distanceText.Text     = string.format("%.0fm", dist)
                data.distanceText.Position = Vector2.new(cx, baseY + ESP_LINE_HEIGHT)
                data.distanceText.Visible  = true
            else
                data.distanceText.Visible = false
            end
        end

        for _, m in ipairs(toCleanup) do destroyMobESP(m) end
    end)
end

local function stopMobESPLoop()
    if mobRenderConn then mobRenderConn:Disconnect(); mobRenderConn = nil end
end

local function setMobESP(enabled)
    MobESPSettings.Enabled = enabled
    if enabled then
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("Humanoid") then
                local model = desc.Parent
                if model and model:IsA("Model") and model:FindFirstChild("HumanoidRootPart") and isMobModel(model) then
                    createMobESP(model)
                end
            end
        end

        mobDescConn = workspace.DescendantAdded:Connect(function(desc)
            if not MobESPSettings.Enabled then return end
            local model = nil
            if desc:IsA("Humanoid") then
                model = desc.Parent
            elseif (desc:IsA("StringValue") and desc.Name == "NPC")
                or (desc:IsA("BoolValue") and desc.Name == "WorldBoss") then
                model = desc.Parent
            end
            if model and model:IsA("Model") and model:FindFirstChild("HumanoidRootPart") then
                task.wait()
                if isMobModel(model) then createMobESP(model) end
            end
        end)

        startMobESPLoop()
    else
        if mobDescConn then mobDescConn:Disconnect(); mobDescConn = nil end
        destroyAllMobESP()
        stopMobESPLoop()
    end
end

