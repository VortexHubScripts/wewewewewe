local UISettingsTab = Window:DrawTab({
    Name = "UI Settings",
    Icon = "paintbrush",
    Type = "Single",
    EnableScrolling = true,
})

do
    local AppearanceSection = UISettingsTab:DrawSection({
        Name = "Appearance",
        Position = "left",
    })

    local themeDropdown
    themeDropdown = AppearanceSection:AddDropdown({
        Name    = "Theme",
        Flag    = "UITheme",
        Default = "Default",
        Values  = { "Default", "Dark Blue", "Dark Green", "Purple Rose", "Skeet", "Custom" },
        Callback = function(v)
            pcall(function()
                Compkiller:SetTheme(v)
            end)
        end,
    })

    local uiReady = false

    local function switchToCustom()
        if not uiReady then return end
        pcall(function()
            Compkiller:SetTheme("Custom")
            themeDropdown:SetValue("Custom")
        end)
    end

    local function applyColor(key, color)
        Compkiller.Colors[key] = color
        if Compkiller.Elements[key] then
            for _, v in next, Compkiller.Elements[key] do
                if v.Element and v.Property then
                    pcall(function() v.Element[v.Property] = color end)
                end
            end
        end
    end

    local CustomColorsSection = UISettingsTab:DrawSection({
        Name = "Custom Colors",
        Position = "left",
    })

    CustomColorsSection:AddColorPicker({
        Name    = "Accent",
        Flag    = "UIColorAccent",
        Default = Color3.fromRGB(255, 255, 255),
        Callback = function(color)
            switchToCustom()
            pcall(function() Compkiller:ChangeHighlightColor(color) end)
        end,
    })

    CustomColorsSection:AddColorPicker({
        Name    = "Background",
        Flag    = "UIColorBackground",
        Default = Color3.fromRGB(30, 30, 30),
        Callback = function(color)
            switchToCustom()
            applyColor("BGDBColor", color)
        end,
    })

    CustomColorsSection:AddColorPicker({
        Name    = "Block BG",
        Flag    = "UIColorBlockBG",
        Default = Color3.fromRGB(35, 35, 35),
        Callback = function(color)
            switchToCustom()
            applyColor("BlockBackground", color)
        end,
    })

    CustomColorsSection:AddColorPicker({
        Name    = "Block",
        Flag    = "UIColorBlock",
        Default = Color3.fromRGB(40, 40, 40),
        Callback = function(color)
            switchToCustom()
            applyColor("BlockColor", color)
        end,
    })

    CustomColorsSection:AddColorPicker({
        Name    = "Dropdown",
        Flag    = "UIColorDropdown",
        Default = Color3.fromRGB(45, 45, 45),
        Callback = function(color)
            switchToCustom()
            applyColor("DropColor", color)
        end,
    })

    CustomColorsSection:AddColorPicker({
        Name    = "Border",
        Flag    = "UIColorBorder",
        Default = Color3.fromRGB(60, 60, 60),
        Callback = function(color)
            switchToCustom()
            applyColor("StrokeColor", color)
        end,
    })

    CustomColorsSection:AddColorPicker({
        Name    = "Highlight Border",
        Flag    = "UIColorHighBorder",
        Default = Color3.fromRGB(255, 255, 255),
        Callback = function(color)
            switchToCustom()
            applyColor("HighStrokeColor", color)
        end,
    })

    CustomColorsSection:AddColorPicker({
        Name    = "Separator",
        Flag    = "UIColorSeparator",
        Default = Color3.fromRGB(50, 50, 50),
        Callback = function(color)
            switchToCustom()
            applyColor("LineColor", color)
        end,
    })

    CustomColorsSection:AddColorPicker({
        Name    = "Text",
        Flag    = "UIColorText",
        Default = Color3.fromRGB(255, 255, 255),
        Callback = function(color)
            switchToCustom()
            applyColor("SwitchColor", color)
        end,
    })

    local ControlsSection = UISettingsTab:DrawSection({
        Name = "Controls",
        Position = "left",
    })

    ControlsSection:AddKeybind({
        Name    = "Toggle Menu",
        Default = "LeftAlt",
        Flag    = "UIToggleKeybind",
        Callback = function(key)
            pcall(function()
                Window:SetMenuKey(key)
            end)
        end,
    })

    uiReady = true
end

