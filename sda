    local function buildServerList()
        local raw = {}
        serverDropdownEntries = {}
        local serversFolder = ReplicatedStorage:FindFirstChild("Servers")
        if serversFolder then
            for _, sv in ipairs(serversFolder:GetChildren()) do
                if sv:IsA("StringValue") and sv.Value ~= "" then
                    local serverId, playerCount = sv.Value:match("^(%S+)%s+(%d+)$")
                    if serverId and playerCount then
                        local regionLabel = ""
                        local regionSV = sv:FindFirstChild("Region")
                        if regionSV and regionSV:IsA("StringValue") and regionSV.Value ~= "" then
                            regionLabel = " " .. (REGION_LABELS[regionSV.Value] or regionSV.Value)
                        end
                        local count = tonumber(playerCount) or 0
                        local display = sv.Name .. " " .. playerCount .. "/20" .. regionLabel
                        table.insert(raw, { display = display, count = count, id = serverId })
                    end
                end
            end
        end
        -- Sort most players to least
        table.sort(raw, function(a, b) return a.count > b.count end)
        local entries = {}
        for _, entry in ipairs(raw) do
            table.insert(entries, entry.display)
            serverDropdownEntries[entry.display] = entry.id
        end
        if #entries == 0 then entries = { "No servers found" } end
        return entries
    end

    local serverInputId = ""

    local function getCurrentServerName()
        local jobId = game.JobId
        local serversFolder = ReplicatedStorage:FindFirstChild("Servers")
        if serversFolder and jobId ~= "" then
            for _, sv in ipairs(serversFolder:GetChildren()) do
                if sv:IsA("StringValue") then
                    local id = sv.Value:match("^(%S+)")
                    if id == jobId then
                        return sv.Name
                    end
                end
            end
        end
        return "Unknown"
    end

    local ServerSection = TeleportTab:DrawSection({
        Name = "Server",
        Position = "right",
    })

    ServerSection:AddLabel({
        Name = "Current Server: " .. getCurrentServerName(),
    })

    local serverDropdown = ServerSection:AddDropdown({
        Name    = "Servers",
        Flag    = "ServerListDropdown",
        Default = "",
        Values  = buildServerList(),
        Callback = function(v)
            selectedServerId = serverDropdownEntries[v]
        end,
    })

    ServerSection:AddButton({
        Name = "Join Selected Server",
        Callback = function()
            if not selectedServerId then
                Notifier.new({ Title = "Server", Content = "No server selected.", Duration = 3 })
                return
            end
            local Event = ReplicatedStorage.Events.DataEvent
            Event:FireServer("ServerTeleport", selectedServerId, 14)
        end,
    })

    ServerSection:AddButton({
        Name = "Refresh Servers",
        Callback = function()
            local newList = buildServerList()
            selectedServerId = nil
            pcall(function()
                serverDropdown:SetValues(newList)
            end)
            Notifier.new({ Title = "Server", Content = "Server list refreshed.", Duration = 2 })
        end,
    })

    ServerSection:AddTextBox({
    	Name = "Input Server ID",
    	Default = "",
    	Placeholder = "Enter server ID...",
    	Numeric = false, -- Optional: true = only allows number input
    	Flag = "ServerIdInput",
    	Callback = function(v)
            serverInputId = v
        end,
    })

    ServerSection:AddButton({
        Name = "Join Server ID",
        Callback = function()
            local id = serverInputId and serverInputId:match("^%s*(.-)%s*$")
            if not id or id == "" then
                Notifier.new({ Title = "Server", Content = "No server ID entered.", Duration = 3 })
                return
            end
            local Event = ReplicatedStorage.Events.DataEvent
            Event:FireServer("ServerTeleport", id, 14)
        end,
    })

    ServerSection:AddButton({
        Name = "Copy Server ID",
        Callback = function()
            local jobId = game.JobId
            setclipboard(jobId)
            Notifier.new({ Title = "Server", Content = "Copied current server ID.", Duration = 2 })
        end,
    })
end

